programa {
  funcao inicio() {
    real salario = 1000
    inteiro dias = 50
    real salarioDiario
    escreva("digite seu salario: ")
    leia(salario)
    escreva("Quantos dias trabalhou no mes")
    leia(dias)
    salarioDiario = salario/dias
    escreva("\nPor dia voce recebe R$" + salarioDiario)
    
  }
}
