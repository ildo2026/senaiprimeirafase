programa {
  funcao inicio() {
  inteiro qtdInicialDeLaranjas, qtdFinalDeLaranjas, qtdFinalDeLaranjasVendidas
  escreva("quantidade inicial de laranjas: ")
  leia (qtdInicialDeLaranjas)
  escreva ("quantidade final de laranjas: ")
  leia (qtdFinalDeLaranjas)
  qtdFinalDeLaranjasVendidas = qtdInicialDeLaranjas - qtdFinalDeLaranjas
  escreva ("quantidade de larajas vendidas: ", qtdFinalDeLaranjasVendidas)
    
  }
}
