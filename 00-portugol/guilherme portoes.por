programa {
  funcao inicio() {
  inteiro clt, pj, estagiarios, totalDeFuncionarios
  escreva ("quantidade total de clt: ")
  leia (clt)
  escreva ("quantidade total de pj: ")
  leia (pj)
  escreva ("quantidade total de estagiarios: ")
  leia (estagiarios)
  totalDeFuncionarios = clt + pj + estagiarios
  escreva ("quantidade total de funcionarios: ", totalDeFuncionarios)

  
  }
}
