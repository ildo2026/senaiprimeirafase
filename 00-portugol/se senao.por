programa {
  funcao inicio() {
    inteiro idade
    escreva("digite sua idade: ")
    leia (idade)
    se(idade < 18 ){
      escreva("Menor")
      escreva("\nNâo ogue joguinhos idiotinhas aqui")
    }senao{
      escreva("Maior")
      escreva("\nTem motivo para entrar no instagram em sala de aula?")
    }
    
  }
}
